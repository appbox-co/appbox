#!/usr/bin/env sh

# Get list of staged files before linting
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

echo "Running linting checks before commit..."
if ! pnpm run lint:fix; then
  echo "Linting failed! Fix the errors before committing."
  exit 1
fi

# Re-add any staged files that may have been modified by lint:fix
if [ -n "$STAGED_FILES" ]; then
  echo "$STAGED_FILES" | while IFS= read -r f; do
    [ -z "$f" ] && continue
    git diff --quiet "$f" 2>/dev/null || git add "$f"
  done
fi

# Keep admin bridge files deterministic in commits.
# You can still run locally with ENABLE_ADMIN_MODULE=true, but staged files
# must remain in canonical "disabled" mode to avoid autofix churn.
if git diff --cached --name-only | grep -E '^apps/web/src/lib/admin/(bridge|availability)\.ts$' >/dev/null; then
  echo "Validating staged admin bridge files..."

  STAGED_BRIDGE=$(git show :apps/web/src/lib/admin/bridge.ts 2>/dev/null || true)
  STAGED_AVAILABILITY=$(git show :apps/web/src/lib/admin/availability.ts 2>/dev/null || true)

  if ! echo "$STAGED_BRIDGE" | grep -q 'export const ADMIN_MODULE_AVAILABLE = false as const'; then
    echo "apps/web/src/lib/admin/bridge.ts must have ADMIN_MODULE_AVAILABLE = false"
    echo "Run: cd apps/web && pnpm admin:bridge"
    exit 1
  fi

  if ! echo "$STAGED_BRIDGE" | grep -q 'return { Shell: null, registry: null }'; then
    echo "apps/web/src/lib/admin/bridge.ts must export null loader return values"
    echo "Run: cd apps/web && pnpm admin:bridge"
    exit 1
  fi

  if ! echo "$STAGED_AVAILABILITY" | grep -q 'export const ADMIN_MODULE_AVAILABLE = false as const'; then
    echo "apps/web/src/lib/admin/availability.ts must have ADMIN_MODULE_AVAILABLE = false"
    echo "Run: cd apps/web && pnpm admin:bridge"
    exit 1
  fi
fi

# Check if any MDX files or contentlayer config have been modified
if git diff --cached --name-only | grep -E '\.mdx$|contentlayer\.config\.ts$'; then
  echo "Content files changed, rebuilding contentlayer..."
  cd apps/web && pnpm contentlayer:build
  if [ $? -ne 0 ]; then
    echo "Contentlayer build failed! Fix the errors before committing."
    exit 1
  fi
  echo "Contentlayer rebuild successful."
fi 

# Run build to catch any build-time errors
echo "Running build check before commit..."
cd "$(git rev-parse --show-toplevel)" || exit 1
if ! pnpm build; then
  echo "Build failed! Fix the errors before committing."
  exit 1
fi
echo "Build check successful."
