    "next-contentlayer2": "^0.5.8",
    "next-intl": "4.13.1",
    "next-themes": "^0.4.6",
    "normalize-path": "^3.0.0",
    "posthog-js": "^1.398.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-intersection-observer": "^10.0.3",
    "react-markdown": "^10.1.0",
    "react-wrap-balancer": "^1.1.1",
    "recharts": "^3.9.2",
    "remark-gfm": "^4.0.1",
    "simplex-noise": "^4.0.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
