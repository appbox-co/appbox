{
  "name": "appbox-web",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "generate-favicons": "node ../../generate-favicons.js src/app/icon-dark.svg .",
    "admin:bridge": "node scripts/generate-admin-bridge.mjs",
    "dev": "set -a; [ -f .env.local ] && . ./.env.local; set +a; pnpm admin:bridge && next dev --turbopack -H ${DEV_HTTPS_HOST:-localhost} --experimental-https --experimental-https-key \"$DEV_HTTPS_KEY\" --experimental-https-cert \"$DEV_HTTPS_CERT\"",
    "dev:http": "next dev --turbopack",
    "build": "pnpm admin:bridge && run-s contentlayer:build next:build",
    "start": "pnpm admin:bridge && node server.mjs",
    "lint": "pnpm admin:bridge && tsc --noEmit && eslint .",
    "lint:fix": "pnpm admin:bridge && tsc --noEmit && eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migrate:app-descriptions": "node scripts/migrate-app-descriptions.mjs",
    "next:build": "next build",
    "contentlayer:build": "contentlayer2 build"
  },
  "dependencies": {
