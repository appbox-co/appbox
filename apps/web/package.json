{
  "name": "appbox-web",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "generate-favicons": "node ../../generate-favicons.js src/app/icon-dark.svg .",
    "admin:bridge": "node scripts/generate-admin-bridge.mjs",
    "dev": "set -a; [ -f .env.local ] && . ./.env.local; set +a; ENABLE_ADMIN_MODULE=${ENABLE_ADMIN_MODULE:-false} pnpm admin:bridge && next dev --turbopack -H ${DEV_HTTPS_HOST:-localhost} --experimental-https --experimental-https-key \"$DEV_HTTPS_KEY\" --experimental-https-cert \"$DEV_HTTPS_CERT\"",
    "dev:admin": "set -a; [ -f .env.local ] && . ./.env.local; set +a; ENABLE_ADMIN_MODULE=true pnpm admin:bridge && next dev --turbopack -H ${DEV_HTTPS_HOST:-localhost} --experimental-https --experimental-https-key \"$DEV_HTTPS_KEY\" --experimental-https-cert \"$DEV_HTTPS_CERT\"",
    "dev:http": "ENABLE_ADMIN_MODULE=false pnpm admin:bridge && next dev --turbopack",
    "dev:http:admin": "ENABLE_ADMIN_MODULE=true pnpm admin:bridge && next dev --turbopack",
    "build": "pnpm admin:bridge && run-s contentlayer:build next:build",
    "start": "pnpm admin:bridge && node server.mjs",
    "lint": "pnpm admin:bridge && tsc --noEmit && eslint .",
    "lint:fix": "pnpm admin:bridge && tsc --noEmit && eslint --fix .",
    "test:reddit-order": "node scripts/test-reddit-order-route.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migrate:app-descriptions": "node scripts/migrate-app-descriptions.mjs",
    "next:build": "next build",
    "contentlayer:build": "contentlayer2 build"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@hookform/resolvers": "^5.4.0",
    "@novnc/novnc": "1.7.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
