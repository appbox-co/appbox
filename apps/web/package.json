    "prettier": "^3.9.4",
    "pretty-quick": "^4.2.2",
    "rehype": "^13.0.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.4",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-code-import": "^1.2.0",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "unist-builder": "^4.0.0",
    "unist-util-visit": "^5.1.0"
  }
}
