{
  "name": "appbox",
  "private": true,
  "scripts": {
    "generate-favicons": "node generate-favicons.js apps/web/src/app/icon-dark.svg apps/web",
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "turbo start",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "prepare": "husky",
    "aislop:staged": "aislop scan --staged",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "aislop": "^0.9.4",
    "eslint": "9.39.2",
    "husky": "^9.1.7",
    "pnpm": "^10.33.0",
    "prettier": "^3.8.2",
    "sharp": "^0.34.5",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": ">=23"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.10",
      "@types/react-dom": "^19.0.4",
      "postcss": "8.5.10",
      "posthog-js>dompurify": "3.4.2",
      "protobufjs": "7.5.6",
      "@microsoft/tsdoc-config>ajv": "6.14.0",
      "mdx-bundler>uuid": "14.0.0"
    }
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "next": "^16.2.4"
  }
}
